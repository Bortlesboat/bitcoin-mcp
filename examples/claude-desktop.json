{
  "_comment": "Hosted API mode (no local node needed)",
  "mcpServers": {
    "bitcoin": {
      "command": "bitcoin-mcp",
      "env": {
        "SATOSHI_API_URL": "https://bitcoinsapi.com"
      }
    }
  },

  "_comment_local": "Local node mode (uncomment and replace the above)",
  "_local_example": {
    "bitcoin": {
      "command": "bitcoin-mcp",
      "env": {
        "BITCOIN_RPC_HOST": "127.0.0.1",
        "BITCOIN_RPC_PORT": "8332"
      }
    }
  }
}
